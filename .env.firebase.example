# ─────────────────────────────────────────────────────────────────────────────
# Firebase Auth Sidecar — Variables de Entorno
# Copia este archivo a .env.local y completa los valores desde la consola de
# Firebase: https://console.firebase.google.com → Configuración del proyecto
# ─────────────────────────────────────────────────────────────────────────────

# Obligatorias para que el Sidecar se active.
# Si alguna falta, el Sidecar se desactiva silenciosamente y la app usa
# el flujo de autenticación existente (NextAuth / AuthService).

NEXT_PUBLIC_FIREBASE_API_KEY=AIzaSy...
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=tu-proyecto.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=tu-proyecto
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=tu-proyecto.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=123456789
NEXT_PUBLIC_FIREBASE_APP_ID=1:123456789:web:abcdef
